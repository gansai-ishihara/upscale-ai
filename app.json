{
  "expo": {
    "name": "UpScale AI",
    "slug": "upscale-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "upscaleai",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gansai.upscale-ai",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "動画を選択してAI超解像処理するためにフォトライブラリへのアクセスが必要です",
        "NSPhotoLibraryAddUsageDescription": "処理済み動画をカメラロールに保存するために必要です",
        "NSUserTrackingUsageDescription": "広告の最適化のために使用します。データは第三者と共有されません。",
        "UIBackgroundModes": [
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.gansai.upscale-ai.upscale"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-media-library",
      "expo-tracking-transparency",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-9059282179467665~2457250987"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "f414da5c-d9da-4c92-8305-3f51b22b9932"
      },
      "router": {}
    },
    "owner": "talkbuddy"
  }
}
